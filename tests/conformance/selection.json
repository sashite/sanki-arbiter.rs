{
	"version": 3,
	"category": "selection",
	"vectors": [
		{
			"id": "selection.single-legal-applied",
			"note": "a single legal candidate fills its slot",
			"boundary": 100,
			"cap": 8,
			"candidates": [{ "id": "a1", "createdAt": 120, "legal": true }],
			"expected": { "result": "applied", "selected": "a1" }
		},
		{
			"id": "selection.single-illegal-unfilled",
			"note": "a single illegal candidate is skipped; with no other candidate the slot is unfilled — there is no illegalmove",
			"boundary": 100,
			"cap": 8,
			"candidates": [{ "id": "a1", "createdAt": 120, "legal": false }],
			"expected": { "result": "unfilled", "selected": null }
		},
		{
			"id": "selection.anterior-latest-legal-wins",
			"note": "two legal premoves (both before the boundary): the later one — the re-premove — wins; an earlier legal premove is superseded",
			"boundary": 100,
			"cap": 8,
			"candidates": [
				{ "id": "a1", "createdAt": 20, "legal": true },
				{ "id": "a2", "createdAt": 60, "legal": true }
			],
			"expected": { "result": "applied", "selected": "a2" }
		},
		{
			"id": "selection.anterior-skip-newest-illegal-then-next",
			"note": "the newest premove is illegal and skipped; the next-newest legal premove wins the anterior window",
			"boundary": 100,
			"cap": 8,
			"candidates": [
				{ "id": "a1", "createdAt": 20, "legal": true },
				{ "id": "a2", "createdAt": 60, "legal": false }
			],
			"expected": { "result": "applied", "selected": "a1" }
		},
		{
			"id": "selection.informed-earliest-legal-wins",
			"note": "two legal live moves (both at/after the boundary): the earliest wins; a later live move for the slot is ineffective",
			"boundary": 0,
			"cap": 8,
			"candidates": [
				{ "id": "a1", "createdAt": 10, "legal": true },
				{ "id": "a2", "createdAt": 20, "legal": true }
			],
			"expected": { "result": "applied", "selected": "a1" }
		},
		{
			"id": "selection.informed-skip-illegal-then-earliest-legal",
			"note": "the earliest live move is illegal and skipped; the next-earliest legal live move wins the informed window",
			"boundary": 0,
			"cap": 8,
			"candidates": [
				{ "id": "a1", "createdAt": 10, "legal": false },
				{ "id": "a2", "createdAt": 20, "legal": true }
			],
			"expected": { "result": "applied", "selected": "a2" }
		},
		{
			"id": "selection.anterior-legal-preferred-over-informed",
			"note": "a legal premove (anterior) binds even though a legal live move (informed) also exists: the anterior window is tried first",
			"boundary": 100,
			"cap": 8,
			"candidates": [
				{ "id": "p1", "createdAt": 50, "legal": true },
				{ "id": "L1", "createdAt": 150, "legal": true }
			],
			"expected": { "result": "applied", "selected": "p1" }
		},
		{
			"id": "selection.fallthrough-to-informed-when-no-legal-anterior",
			"note": "the only premove (anterior) is illegal, so selection falls through to the earliest legal live move (informed)",
			"boundary": 100,
			"cap": 8,
			"candidates": [
				{ "id": "p1", "createdAt": 50, "legal": false },
				{ "id": "L1", "createdAt": 150, "legal": true }
			],
			"expected": { "result": "applied", "selected": "L1" }
		},
		{
			"id": "selection.all-illegal-both-windows-unfilled",
			"note": "no legal candidate in either window (an illegal premove and an illegal live move): both skipped, the slot is unfilled",
			"boundary": 100,
			"cap": 8,
			"candidates": [
				{ "id": "p1", "createdAt": 50, "legal": false },
				{ "id": "L1", "createdAt": 150, "legal": false }
			],
			"expected": { "result": "unfilled", "selected": null }
		},
		{
			"id": "selection.anterior-tie-createdat-largest-id-first",
			"note": "equal canonical timing in the anterior window: the more recent is the larger id, so b2 (legal) is considered first and wins",
			"boundary": 100,
			"cap": 8,
			"candidates": [
				{ "id": "b1", "createdAt": 60, "legal": true },
				{ "id": "b2", "createdAt": 60, "legal": true }
			],
			"expected": { "result": "applied", "selected": "b2" }
		},
		{
			"id": "selection.informed-tie-createdat-smallest-id-first",
			"note": "equal canonical timing in the informed window: the earliest is the smaller id, so b1 (legal) is considered first and wins",
			"boundary": 0,
			"cap": 8,
			"candidates": [
				{ "id": "b1", "createdAt": 20, "legal": true },
				{ "id": "b2", "createdAt": 20, "legal": true }
			],
			"expected": { "result": "applied", "selected": "b1" }
		},
		{
			"id": "selection.informed-tie-createdat-first-legal-by-id",
			"note": "equal canonical timing in the informed window, ordered by id ascending: b1 (illegal) is skipped, b2 (legal) is selected",
			"boundary": 0,
			"cap": 8,
			"candidates": [
				{ "id": "b1", "createdAt": 20, "legal": false },
				{ "id": "b2", "createdAt": 20, "legal": true }
			],
			"expected": { "result": "applied", "selected": "b2" }
		},
		{
			"id": "selection.cap-anterior-most-recent-K-buries-older-legal",
			"note": "cap K=2 in the anterior window considers the 2 MOST RECENT premoves (both illegal); an older legal premove is beyond the cap, so the slot is unfilled — flooding one's own recent premoves is self-harm",
			"boundary": 1000,
			"cap": 2,
			"candidates": [
				{ "id": "a1", "createdAt": 10, "legal": true },
				{ "id": "a2", "createdAt": 800, "legal": false },
				{ "id": "a3", "createdAt": 900, "legal": false }
			],
			"expected": { "result": "unfilled", "selected": null }
		},
		{
			"id": "selection.cap-anterior-within-K-applied",
			"note": "cap K=3 in the anterior window reaches the older legal premove, which fills the slot",
			"boundary": 1000,
			"cap": 3,
			"candidates": [
				{ "id": "a1", "createdAt": 10, "legal": true },
				{ "id": "a2", "createdAt": 800, "legal": false },
				{ "id": "a3", "createdAt": 900, "legal": false }
			],
			"expected": { "result": "applied", "selected": "a1" }
		},
		{
			"id": "selection.cap-informed-earliest-K-buries-later-legal",
			"note": "cap K=2 in the informed window considers the 2 EARLIEST live moves (both illegal); a later legal live move is beyond the cap, so the slot is unfilled",
			"boundary": 0,
			"cap": 2,
			"candidates": [
				{ "id": "a1", "createdAt": 10, "legal": false },
				{ "id": "a2", "createdAt": 20, "legal": false },
				{ "id": "a3", "createdAt": 30, "legal": true }
			],
			"expected": { "result": "unfilled", "selected": null }
		},
		{
			"id": "selection.cap-informed-within-K-applied",
			"note": "cap K=3 in the informed window reaches the later legal live move, which fills the slot",
			"boundary": 0,
			"cap": 3,
			"candidates": [
				{ "id": "a1", "createdAt": 10, "legal": false },
				{ "id": "a2", "createdAt": 20, "legal": false },
				{ "id": "a3", "createdAt": 30, "legal": true }
			],
			"expected": { "result": "applied", "selected": "a3" }
		},
		{
			"id": "selection.orders-by-timing-not-input-order",
			"note": "candidates given out of order are partitioned and sorted before the scan; here all are informed, earliest legal (a2) wins",
			"boundary": 0,
			"cap": 8,
			"candidates": [
				{ "id": "a3", "createdAt": 70, "legal": true },
				{ "id": "a1", "createdAt": 10, "legal": false },
				{ "id": "a2", "createdAt": 20, "legal": true }
			],
			"expected": { "result": "applied", "selected": "a2" }
		}
	]
